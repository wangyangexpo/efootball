# 复制此文件为 .env 并填入真实值，.env 已被 .gitignore 忽略，不会提交到 Git
# cp .env.example .env

# MySQL 配置
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=springboot_demo
DB_USER=root

# 应用镜像（用于 docker-compose.prod.yml）
APP_IMAGE=your-registry/your-repo
VERSION=latest

# 部署服务器信息（用于 deploy.sh）
IMAGE_NAME=your-registry/your-repo
SERVER_IP=your.server.ip
SERVER_USER=your-username

# Umami 数据分析配置
UMAMI_APP_SECRET=your_random_secret_string

# 阿里云 OSS 配置
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET_NAME=your_bucket_name
OSS_URL_PREFIX=https://your-bucket-name.oss-cn-shanghai.aliyuncs.com
